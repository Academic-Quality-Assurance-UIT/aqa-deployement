{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["BACKEND_URL", "BACKEND_API_URL", "NEXT_PUBLIC_API_URL_V2"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": []
    },
    "test": {
      "dependsOn": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "format": {
      "dependsOn": [],
      "cache": false
    }
  }
}
